# ── Conexión con la nube de Zepp / Huami ──────────────────────────────
# Elige UNA de las dos formas de autenticación.

# Opción A (RECOMENDADA): token pre-extraído.
#   Se saca una sola vez con un proxy (HTTP Toolkit / Fiddler) capturando
#   la cabecera 'apptoken' de la app Zepp, o con argrento/huami-token.
#   Evita el rate-limit del endpoint de login.
# ZEPP_APP_TOKEN=
# ZEPP_USER_ID=
# ZEPP_API_HOST=

# Opción B: email + contraseña de tu cuenta Zepp.
#   Hace el login completo. No lo llames muy seguido (rate-limit 0103).
# ZEPP_EMAIL=
# ZEPP_PASSWORD=

# ── Opcionales ────────────────────────────────────────────────────────
USER_NAME=Atleta
# Zepp NO expone el nivel de batería del Helio Strap por su API. Déjalo vacío
# para que la UI muestre "—"; pon un número solo si quieres forzar un valor.
# DEVICE_BATTERY=
CACHE_TTL_SECONDS=900
# Contraseña simple para proteger el dashboard (la pide el frontend al cargar).
# Vacía = sitio abierto. Ponla en Vercel para exigir contraseña en producción.
# SITE_PASSWORD=

# Brief diario con IA (opcional). La clave se queda sólo en el backend.
# Sin OPENAI_API_KEY, la app genera un brief local básico.
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_SECONDS=30

# Si no defines NINGUNA credencial, el backend sirve datos demo
# (útil para cablear la UI antes de tener el token real).
