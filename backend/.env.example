# ── Conexión con la nube de Zepp / Huami ──────────────────────────────
# Elige UNA de las dos formas de autenticación.

# Opción A (RECOMENDADA): token pre-extraído.
#   Se saca una sola vez con un proxy (HTTP Toolkit / Fiddler) capturando
#   la cabecera 'apptoken' de la app Zepp, o con argrento/huami-token.
#   Evita el rate-limit del endpoint de login.
# ZEPP_APP_TOKEN=
# ZEPP_USER_ID=
# ZEPP_API_HOST=

# Opción B: email + contraseña de tu cuenta Zepp.
#   Hace el login completo. No lo llames muy seguido (rate-limit 0103).
# ZEPP_EMAIL=
# ZEPP_PASSWORD=

# ── Opcionales ────────────────────────────────────────────────────────
USER_NAME=Atleta
DEVICE_BATTERY=78
CACHE_TTL_SECONDS=900

# Si no defines NINGUNA credencial, el backend sirve datos demo
# (útil para cablear la UI antes de tener el token real).
